<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>{% block title %}예금하기 좋은 날{% endblock %}</title>
<meta name="description" content="{% block meta_description %}오늘 가장 높은 CMA 금리, 파킹통장 금리, 단기채권 ETF 수익률을 한눈에 비교하세요.{% endblock %}">
<meta name="robots" content="index, follow">
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
<link href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css" rel="stylesheet"/>
<script id="tailwind-config">
  tailwind.config = {
    theme: {
      extend: {
        colors: {
          "primary": "#0058be",
          "primary-container": "#2170e4",
          "on-primary": "#ffffff",
          "on-primary-container": "#fefcff",
          "secondary": "#495e8a",
          "secondary-container": "#b6ccff",
          "on-secondary-container": "#405682",
          "tertiary": "#aa2d32",
          "on-tertiary": "#ffffff",
          "surface": "#f8f9fd",
          "surface-bright": "#f8f9fd",
          "surface-container-lowest": "#ffffff",
          "surface-container-low": "#f2f3f7",
          "surface-container": "#edeef2",
          "surface-container-high": "#e7e8ec",
          "surface-container-highest": "#e1e2e6",
          "on-surface": "#191c1f",
          "on-surface-variant": "#424754",
          "outline": "#727785",
          "outline-variant": "#c2c6d6",
          "background": "#f8f9fd",
        },
        borderRadius: {
          "DEFAULT": "1rem",
          "sm": "0.5rem",
          "md": "1.5rem",
          "lg": "2rem",
          "xl": "3rem",
          "full": "9999px",
        },
        fontFamily: {
          sans: ["Pretendard", "sans-serif"],
        }
      }
    }
  }
</script>
<style>
  body { font-family: 'Pretendard', sans-serif; background-color: #f8f9fd; color: #191c1f; min-height: 100dvh; }
  .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
  .icon-filled { font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
  .tab-btn { transition: background 0.15s, color 0.15s; }
  .accordion-body { overflow: hidden; max-height: 0; transition: max-height 0.3s ease; }
  .accordion-body.open { max-height: 300px; }
  .chevron { transition: transform 0.25s; }
  .chevron.open { transform: rotate(180deg); }
</style>
{% block extra_head %}{% endblock %}
</head>
<body class="bg-background pb-28">

<!-- Header -->
<header class="fixed top-0 w-full z-50 bg-[#f8f9fd]/80 backdrop-blur-md flex justify-between items-center px-6 py-4">
  <div class="flex items-center gap-3">
    <button onclick="toggleNav()" aria-label="메뉴 열기">
      <span class="material-symbols-outlined text-primary">menu</span>
    </button>
    <a href="/" class="text-primary font-black tracking-tight text-lg">예금하기 좋은 날</a>
  </div>
  <time class="text-xs text-on-surface-variant font-medium">{{ updated_at }} 기준</time>
</header>

<!-- Nav Overlay -->
<div id="nav-overlay" class="fixed inset-0 z-40 bg-black/30 hidden" onclick="toggleNav()"></div>
<nav id="nav-drawer" class="fixed top-0 left-0 h-full w-64 z-50 bg-surface-container-lowest shadow-2xl -translate-x-full transition-transform duration-300 pt-16 px-5">
  <p class="text-xs font-bold text-on-surface-variant tracking-widest mb-4">메뉴</p>
  <ul class="space-y-1">
    <li><a href="/" class="flex items-center gap-3 px-4 py-3 rounded-DEFAULT {% block nav_home_active %}text-on-surface-variant font-semibold hover:bg-surface-container-low{% endblock %} text-sm"><span class="material-symbols-outlined text-lg">home</span>홈</a></li>
    <li><a href="/cma/" class="flex items-center gap-3 px-4 py-3 rounded-DEFAULT {% block nav_cma_active %}text-on-surface-variant font-semibold hover:bg-surface-container-low{% endblock %} text-sm"><span class="material-symbols-outlined text-lg">trending_up</span>CMA 금리</a></li>
    <li><a href="/parking/" class="flex items-center gap-3 px-4 py-3 rounded-DEFAULT {% block nav_parking_active %}text-on-surface-variant font-semibold hover:bg-surface-container-low{% endblock %} text-sm"><span class="material-symbols-outlined text-lg">account_balance</span>파킹통장</a></li>
    <li><a href="/etf/" class="flex items-center gap-3 px-4 py-3 rounded-DEFAULT {% block nav_etf_active %}text-on-surface-variant font-semibold hover:bg-surface-container-low{% endblock %} text-sm"><span class="material-symbols-outlined text-lg">candlestick_chart</span>ETF 시세</a></li>
    <li><a href="/deposit/" class="flex items-center gap-3 px-4 py-3 rounded-DEFAULT {% block nav_deposit_active %}text-on-surface-variant font-semibold hover:bg-surface-container-low{% endblock %} text-sm"><span class="material-symbols-outlined text-lg">savings</span>예금 금리</a></li>
  </ul>
</nav>

{% block content %}{% endblock %}

<!-- Bottom Nav -->
<nav class="fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-4 pb-6 pt-3 bg-white/90 backdrop-blur-xl rounded-t-[2rem] shadow-[0_-8px_30px_rgba(0,88,190,0.08)]">
  <a href="/" class="flex flex-col items-center {% block bottom_home_active %}text-on-surface-variant hover:text-primary transition-colors{% endblock %}">
    <span class="material-symbols-outlined {% block bottom_home_icon %}text-xl{% endblock %}">home</span>
    <span class="text-[11px] {% block bottom_home_label %}font-semibold{% endblock %} mt-0.5">홈</span>
  </a>
  <a href="/cma/" class="flex flex-col items-center {% block bottom_cma_active %}text-on-surface-variant hover:text-primary transition-colors{% endblock %}">
    <span class="material-symbols-outlined {% block bottom_cma_icon %}text-xl{% endblock %}">analytics</span>
    <span class="text-[11px] {% block bottom_cma_label %}font-semibold{% endblock %} mt-0.5">금리비교</span>
  </a>
  <a href="#" class="flex flex-col items-center text-on-surface-variant hover:text-primary transition-colors">
    <span class="material-symbols-outlined text-xl">calculate</span>
    <span class="text-[11px] font-semibold mt-0.5">계산기</span>
  </a>
  <a href="#" class="flex flex-col items-center text-on-surface-variant hover:text-primary transition-colors">
    <span class="material-symbols-outlined text-xl">menu_book</span>
    <span class="text-[11px] font-semibold mt-0.5">가이드</span>
  </a>
</nav>

<script>
  function toggleNav() {
    const drawer = document.getElementById('nav-drawer');
    const overlay = document.getElementById('nav-overlay');
    const isOpen = !drawer.classList.contains('-translate-x-full');
    drawer.classList.toggle('-translate-x-full', isOpen);
    overlay.classList.toggle('hidden', isOpen);
  }

  function toggleAccordion(btn) {
    const body = btn.nextElementSibling;
    const chevron = btn.querySelector('.chevron');
    const isOpen = body.classList.contains('open');
    document.querySelectorAll('.accordion-body').forEach(b => b.classList.remove('open'));
    document.querySelectorAll('.chevron').forEach(c => c.classList.remove('open'));
    if (!isOpen) {
      body.classList.add('open');
      chevron.classList.add('open');
    }
  }
</script>
{% block extra_scripts %}{% endblock %}
</body>
</html>
