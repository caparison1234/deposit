{% extends "base.html.j2" %}

{% block title %}파킹통장 금리 비교 | 예금하기 좋은 날{% endblock %}
{% block nav_parking_active %}bg-secondary-container text-primary font-bold{% endblock %}
{% block meta_description %}오늘 가장 높은 파킹통장 금리를 한눈에 비교하세요. 시중은행·인터넷은행 파킹통장 금리 랭킹과 하루 이자 계산기를 제공합니다.{% endblock %}
{% block canonical_url %}https://caparison1234.github.io/deposit/parking/{% endblock %}
{% block og_title %}파킹통장 금리 비교 2026 | 시중·인터넷은행 랭킹 | 예금하기 좋은 날{% endblock %}
{% block og_description %}오늘 파킹통장 금리 순위. 카카오·케이·토스뱅크 등 인터넷은행 포함 매일 업데이트.{% endblock %}
{% block og_url %}https://caparison1234.github.io/deposit/parking/{% endblock %}

{% block extra_head %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "홈", "item": "/"},
    {"@type": "ListItem", "position": 2, "name": "파킹통장 금리 비교", "item": "/parking/"}
  ]
}
</script>
{% endblock %}

{% block content %}
<main class="pt-20 max-w-2xl mx-auto">

  <!-- Breadcrumb -->
  <div class="px-6 pt-3 pb-1 flex items-center gap-1.5 text-xs text-on-surface-variant">
    <a href="{{ site_root }}/" class="hover:text-primary transition-colors font-medium">홈</a>
    <span class="material-symbols-outlined text-sm">chevron_right</span>
    <span class="text-on-surface font-semibold">파킹통장 금리 비교</span>
  </div>

  <!-- Hero -->
  <section class="px-6 pt-4 pb-6">
    <p class="text-tertiary font-bold text-xs tracking-widest mb-2">PARKING ACCOUNT RATE RANKING</p>
    <h1 class="text-2xl font-extrabold text-on-surface leading-tight tracking-tight mb-1">
      파킹통장 금리 비교
    </h1>
    <p class="text-sm text-on-surface-variant font-medium mb-5">{{ updated_at }} 기준 · {{ parking_items | length if parking_items else 0 }}개 상품</p>

    <!-- Filter Tabs -->
    <div class="flex gap-2 flex-wrap">
      <button class="tab-btn px-4 py-2 rounded-full text-sm font-bold bg-primary text-white" data-filter="all">전체</button>
      <button class="tab-btn px-4 py-2 rounded-full text-sm font-bold bg-surface-container text-on-surface-variant" data-filter="시중은행">시중은행</button>
      <button class="tab-btn px-4 py-2 rounded-full text-sm font-bold bg-surface-container text-on-surface-variant" data-filter="인터넷은행">인터넷은행</button>
    </div>
  </section>

  <!-- Ad Slot Top -->
  <section class="px-6 mb-6">
    <div id="ad-top" class="ad-slot w-full min-h-[90px] bg-surface-container rounded-DEFAULT flex items-center justify-center border border-dashed border-outline-variant/40" data-slot="slot-top">
      <!-- Adsense slot-top: insert data-ad-client / data-ad-slot here -->
      <span class="text-xs text-on-surface-variant font-medium tracking-widest">광 고</span>
    </div>
  </section>

  <!-- Rate Table -->
  <section class="px-6 mb-6">
    <div class="bg-surface-container-lowest rounded-md overflow-hidden" style="box-shadow:0 4px 24px rgba(0,88,190,0.07);">

      <!-- Header Row -->
      <div class="grid grid-cols-[2rem_1fr_5rem_5rem_5rem_5rem_5rem] items-center px-5 py-3 bg-surface-container-low gap-2">
        <span class="text-xs font-bold text-on-surface-variant">순위</span>
        <span class="text-xs font-bold text-on-surface-variant">은행명 · 상품명</span>
        <span class="text-right text-xs font-bold text-on-surface-variant">금리</span>
        <span class="text-right text-xs font-bold text-on-surface-variant hidden sm:block">예금자보호</span>
        <span class="text-right text-xs font-bold text-on-surface-variant hidden sm:block">가입채널</span>
        <span class="text-right text-xs font-bold text-on-surface-variant hidden md:block">기준일</span>
      </div>

      {% if parking_items %}
        {% for item in parking_items %}
        {% set loop_first = loop.first %}
        <div class="rate-row grid grid-cols-[2rem_1fr_5rem_5rem_5rem_5rem_5rem] items-center px-5 py-4 gap-2 {% if loop_first %}border-l-4 border-primary bg-gradient-to-r from-primary/5 to-transparent{% elif loop.index is odd %}bg-[#f9fafb]{% else %}bg-surface-container-lowest{% endif %}"
             data-type="{{ item.bank_type | default('시중은행') }}">
          <span class="text-lg font-black {% if loop_first %}text-primary{% else %}text-on-surface-variant{% endif %}">{{ item.rank | default(loop.index) }}</span>
          <div class="min-w-0">
            <p class="font-bold text-on-surface text-sm truncate">{{ item.firm }}</p>
            <p class="text-xs text-on-surface-variant mt-0.5 truncate">{{ item.product_name }}</p>
          </div>
          <span class="text-right text-xl font-black {% if loop_first %}text-primary{% else %}text-on-surface{% endif %}">{{ item.rate }}<span class="text-sm font-bold">%</span></span>
          <span class="text-right hidden sm:block">
            {% if item.protection %}
            <span class="text-xs bg-secondary-container text-on-secondary-container font-bold px-2 py-1 rounded-full">보호</span>
            {% else %}
            <span class="text-xs bg-surface-container text-on-surface-variant font-bold px-2 py-1 rounded-full">비보호</span>
            {% endif %}
          </span>
          <span class="text-right text-xs text-on-surface-variant font-semibold hidden sm:block">{{ item.join_channel | default('앱') }}</span>
          <span class="text-right text-xs text-on-surface-variant hidden md:block">{{ item.as_of | default('') }}</span>
        </div>
        {% if not loop.last %}<div class="h-px bg-outline-variant/20 mx-5"></div>{% endif %}
        {% endfor %}
      {% else %}
        <!-- Static fallback when no data collected yet -->
        <div class="rate-row grid grid-cols-[2rem_1fr_5rem_5rem_5rem_5rem_5rem] items-center px-5 py-4 gap-2 border-l-4 border-primary bg-gradient-to-r from-primary/5 to-transparent" data-type="인터넷은행">
          <span class="text-lg font-black text-primary">1</span>
          <div class="min-w-0">
            <p class="font-bold text-on-surface text-sm">토스뱅크</p>
            <p class="text-xs text-on-surface-variant mt-0.5">토스뱅크 통장</p>
          </div>
          <span class="text-right text-xl font-black text-primary">—<span class="text-sm font-bold">%</span></span>
          <span class="text-right hidden sm:block"><span class="text-xs bg-secondary-container text-on-secondary-container font-bold px-2 py-1 rounded-full">보호</span></span>
          <span class="text-right text-xs text-on-surface-variant font-semibold hidden sm:block">앱</span>
          <span class="text-right text-xs text-on-surface-variant hidden md:block">데이터 수집 중</span>
        </div>
        <div class="h-px bg-outline-variant/20 mx-5"></div>
        <div class="rate-row grid grid-cols-[2rem_1fr_5rem_5rem_5rem_5rem_5rem] items-center px-5 py-4 gap-2 bg-surface-container-lowest" data-type="인터넷은행">
          <span class="text-lg font-black text-on-surface-variant">2</span>
          <div class="min-w-0">
            <p class="font-bold text-on-surface text-sm">카카오뱅크</p>
            <p class="text-xs text-on-surface-variant mt-0.5">세이프박스</p>
          </div>
          <span class="text-right text-xl font-black text-on-surface">—<span class="text-sm font-bold">%</span></span>
          <span class="text-right hidden sm:block"><span class="text-xs bg-secondary-container text-on-secondary-container font-bold px-2 py-1 rounded-full">보호</span></span>
          <span class="text-right text-xs text-on-surface-variant font-semibold hidden sm:block">앱</span>
          <span class="text-right text-xs text-on-surface-variant hidden md:block">데이터 수집 중</span>
        </div>
        <div class="h-px bg-outline-variant/20 mx-5"></div>
        <div class="rate-row grid grid-cols-[2rem_1fr_5rem_5rem_5rem_5rem_5rem] items-center px-5 py-4 gap-2 bg-[#f9fafb]" data-type="인터넷은행">
          <span class="text-lg font-black text-on-surface-variant">3</span>
          <div class="min-w-0">
            <p class="font-bold text-on-surface text-sm">케이뱅크</p>
            <p class="text-xs text-on-surface-variant mt-0.5">플러스박스</p>
          </div>
          <span class="text-right text-xl font-black text-on-surface">—<span class="text-sm font-bold">%</span></span>
          <span class="text-right hidden sm:block"><span class="text-xs bg-secondary-container text-on-secondary-container font-bold px-2 py-1 rounded-full">보호</span></span>
          <span class="text-right text-xs text-on-surface-variant font-semibold hidden sm:block">앱</span>
          <span class="text-right text-xs text-on-surface-variant hidden md:block">데이터 수집 중</span>
        </div>
        <div class="h-px bg-outline-variant/20 mx-5"></div>
        <div class="rate-row grid grid-cols-[2rem_1fr_5rem_5rem_5rem_5rem_5rem] items-center px-5 py-4 gap-2 bg-surface-container-lowest" data-type="시중은행">
          <span class="text-lg font-black text-on-surface-variant">4</span>
          <div class="min-w-0">
            <p class="font-bold text-on-surface text-sm">우리은행</p>
            <p class="text-xs text-on-surface-variant mt-0.5">우리 파킹통장</p>
          </div>
          <span class="text-right text-xl font-black text-on-surface">—<span class="text-sm font-bold">%</span></span>
          <span class="text-right hidden sm:block"><span class="text-xs bg-secondary-container text-on-secondary-container font-bold px-2 py-1 rounded-full">보호</span></span>
          <span class="text-right text-xs text-on-surface-variant font-semibold hidden sm:block">앱·지점</span>
          <span class="text-right text-xs text-on-surface-variant hidden md:block">데이터 수집 중</span>
        </div>
        <div class="h-px bg-outline-variant/20 mx-5"></div>
        <div class="rate-row grid grid-cols-[2rem_1fr_5rem_5rem_5rem_5rem_5rem] items-center px-5 py-4 gap-2 bg-[#f9fafb]" data-type="시중은행">
          <span class="text-lg font-black text-on-surface-variant">5</span>
          <div class="min-w-0">
            <p class="font-bold text-on-surface text-sm">신한은행</p>
            <p class="text-xs text-on-surface-variant mt-0.5">신한 머니박스</p>
          </div>
          <span class="text-right text-xl font-black text-on-surface">—<span class="text-sm font-bold">%</span></span>
          <span class="text-right hidden sm:block"><span class="text-xs bg-secondary-container text-on-secondary-container font-bold px-2 py-1 rounded-full">보호</span></span>
          <span class="text-right text-xs text-on-surface-variant font-semibold hidden sm:block">앱·지점</span>
          <span class="text-right text-xs text-on-surface-variant hidden md:block">데이터 수집 중</span>
        </div>
      {% endif %}

      <!-- Table footnote -->
      <div class="px-5 py-3 bg-surface-container-low">
        <p class="text-xs text-on-surface-variant">* 금리는 세전 연이율 기준이며, 실제 수익률은 과세 후 달라질 수 있습니다. 우대 조건 미충족 시 기본 금리 적용.</p>
      </div>
    </div>
  </section>

  <!-- Interest Calculator -->
  <section class="px-6 mb-6">
    <p class="text-xs font-bold text-on-surface-variant tracking-widest mb-3">하루 이자 계산기</p>
    <div class="bg-surface-container-lowest rounded-md px-5 py-5" style="box-shadow:0 2px 12px rgba(0,0,0,0.05);">
      <label class="block text-sm font-bold text-on-surface mb-2" for="calc-amount">예치 금액 (원)</label>
      <div class="flex gap-3 items-center mb-4">
        <input id="calc-amount" type="number" min="0" step="10000" placeholder="예: 10000000"
               class="flex-1 border border-outline-variant rounded-DEFAULT px-4 py-3 text-sm font-semibold text-on-surface bg-surface focus:outline-none focus:border-primary transition-colors"/>
        <span class="text-sm font-bold text-on-surface-variant shrink-0">원</span>
      </div>
      <p class="text-xs text-on-surface-variant mb-1">연 금리 직접 입력 (기본값: 최고금리)</p>
      <div class="flex gap-3 items-center mb-5">
        <input id="calc-rate" type="number" min="0" max="20" step="0.01" placeholder="예: 3.50"
               class="w-32 border border-outline-variant rounded-DEFAULT px-4 py-3 text-sm font-semibold text-on-surface bg-surface focus:outline-none focus:border-primary transition-colors"/>
        <span class="text-sm font-bold text-on-surface-variant shrink-0">% 연이율</span>
      </div>
      <div class="bg-surface-container rounded-DEFAULT px-4 py-4 flex items-center justify-between">
        <span class="text-sm font-bold text-on-surface-variant">하루 이자 (세전)</span>
        <span id="calc-result" class="text-2xl font-black text-primary">—원</span>
      </div>
      <p class="text-xs text-on-surface-variant mt-3">* 실제 이자는 이자소득세 15.4% 원천징수 후 지급됩니다.</p>
    </div>
  </section>

  <!-- Ad Slot Mid -->
  <section class="px-6 mb-6">
    <div id="ad-mid" class="ad-slot w-full min-h-[250px] bg-surface-container rounded-DEFAULT flex items-center justify-center border border-dashed border-outline-variant/40" data-slot="slot-mid">
      <!-- Adsense slot-mid: insert data-ad-client / data-ad-slot here -->
      <span class="text-xs text-on-surface-variant font-medium tracking-widest">광 고</span>
    </div>
  </section>

  <!-- Related Links -->
  <section class="px-6 mb-6">
    <p class="text-xs font-bold text-on-surface-variant tracking-widest mb-3">관련 금리 보기</p>
    <div class="grid grid-cols-2 gap-3">
      <a href="{{ site_root }}/cma/" class="flex items-center justify-between bg-surface-container-lowest rounded-DEFAULT px-4 py-4 font-bold text-sm text-on-surface hover:bg-surface-container-low transition-colors" style="box-shadow:0 2px 8px rgba(0,0,0,0.05);">
        <span>CMA 금리와 비교하기</span>
        <span class="material-symbols-outlined text-primary text-lg">chevron_right</span>
      </a>
      <a href="{{ site_root }}/deposit/" class="flex items-center justify-between bg-surface-container-lowest rounded-DEFAULT px-4 py-4 font-bold text-sm text-on-surface hover:bg-surface-container-low transition-colors" style="box-shadow:0 2px 8px rgba(0,0,0,0.05);">
        <span>정기예금 금리 보기</span>
        <span class="material-symbols-outlined text-primary text-lg">chevron_right</span>
      </a>
    </div>
  </section>

  <!-- Disclaimer -->
  <section class="px-6 mb-4">
    <p class="text-xs text-on-surface-variant/60 leading-relaxed">본 사이트의 금리 정보는 자동 수집된 참고 자료로, 투자 권유 또는 금융 상품 추천이 아닙니다. 실제 가입 전 각 금융사 공식 사이트를 반드시 확인하세요. © 2026 예금하기 좋은 날</p>
  </section>

</main>
{% endblock %}

{% block extra_scripts %}
<script>
  // Filter tabs
  const tabs = document.querySelectorAll('.tab-btn');
  const rows = document.querySelectorAll('.rate-row');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => {
        t.classList.remove('bg-primary', 'text-white');
        t.classList.add('bg-surface-container', 'text-on-surface-variant');
      });
      tab.classList.add('bg-primary', 'text-white');
      tab.classList.remove('bg-surface-container', 'text-on-surface-variant');

      const filter = tab.dataset.filter;
      let rank = 1;
      rows.forEach(row => {
        const show = filter === 'all' || row.dataset.type === filter;
        row.style.display = show ? 'grid' : 'none';
        if (show) {
          row.querySelector('span:first-child').textContent = rank++;
        }
      });
    });
  });

  // Interest calculator
  function calcInterest() {
    const amount = parseFloat(document.getElementById('calc-amount').value) || 0;
    const rate = parseFloat(document.getElementById('calc-rate').value) || 0;
    const resultEl = document.getElementById('calc-result');
    if (amount > 0 && rate > 0) {
      const daily = Math.floor(amount * (rate / 100) / 365);
      resultEl.textContent = daily.toLocaleString('ko-KR') + '원';
    } else {
      resultEl.textContent = '—원';
    }
  }

  document.getElementById('calc-amount').addEventListener('input', calcInterest);
  document.getElementById('calc-rate').addEventListener('input', calcInterest);
</script>
{% endblock %}
